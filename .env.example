# Firebase Configuration
# Copie este arquivo para .env.local e preencha com suas credenciais
# Encontre esses valores em: Firebase Console > Settings > Project Settings

# Chave de API do Firebase
VITE_FIREBASE_API_KEY=sua_api_key_aqui

# Domínio de autenticação
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com

# ID do projeto no Firebase
VITE_FIREBASE_PROJECT_ID=seu-projeto-id

# Bucket de armazenamento do Firebase
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com

# ID do remetente de mensagens
VITE_FIREBASE_MESSAGING_SENDER_ID=seu-sender-id

# ID da aplicação no Firebase
VITE_FIREBASE_APP_ID=seu-app-id

# ID de medição (opcional, para Google Analytics)
VITE_FIREBASE_MEASUREMENT_ID=seu-measurement-id
